# JSONPlaceholder is a public, auth-free API. No credentials required.
# This file exists so generated CLIs all share the same .env shape.

# @optional
# JSONPLACEHOLDER_BASE_URL — override the API base URL. Used by integration tests.
# JSONPLACEHOLDER_BASE_URL=http://127.0.0.1:3000

# @optional
# @how-to-get N/A — JSONPlaceholder is unauthenticated. Set to any non-empty value
#                   to satisfy auth_missing checks if your harness expects one.
# JSONPLACEHOLDER_API_KEY=
