# Exemplar CLI environment variables.
# This file is the placeholder shape every clify-generated CLI inherits.
# Copy to `.env` (gitignored) and fill in values.

# === Static-token schemes (bearer / api-key-header / basic) ===

# @required
# @how-to-get https://docs.exemplar.test/dashboard/api-keys
# @format Bearer-style opaque token (40+ chars). Treat as a secret.
# EXEMPLAR_API_KEY=your_exemplar_api_key_here

# === OAuth-refresh scheme (uncomment for oauth-refresh APIs) ===
# Three creds required together. The CLI mints a short-lived access token
# from these on first use and caches it under ~/.config/exemplar-cli/.

# @required-when scheme=oauth-refresh
# @how-to-get https://docs.exemplar.test/oauth/self-client (long-lived refresh token)
# EXEMPLAR_REFRESH_TOKEN=your_exemplar_refresh_token_here

# @required-when scheme=oauth-refresh
# @how-to-get https://docs.exemplar.test/api-console (registered client id)
# EXEMPLAR_CLIENT_ID=your_exemplar_client_id_here

# @required-when scheme=oauth-refresh
# @how-to-get same place as client id
# @format opaque secret string. Treat as a secret.
# EXEMPLAR_CLIENT_SECRET=your_exemplar_client_secret_here

# @optional
# Set to 1 to skip writing ~/.config/exemplar-cli/credentials.json on
# every refresh — useful for ephemeral CI runs and account-switching flows.
# EXEMPLAR_NO_CACHE=1

# === Test override ===

# @optional
# @validation-command items list
# Override the API base URL — used by integration tests to point at a mock server.
# EXEMPLAR_BASE_URL=http://127.0.0.1:3000
